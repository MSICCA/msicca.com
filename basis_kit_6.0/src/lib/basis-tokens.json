  "typography": {
    "fonts": {
      "display": {
        "family": "IBM Plex Mono",
        "category": "monospace",
        "weights": [400, 500, 600, 700],
        "usage": "Headings H1-H4, buttons, data tables, badges, technical elements"
      },
      "body": {
        "family": "Inter",
        "category": "sans-serif",
        "weights": [400, 500, 600],
        "usage": "Paragraphs, form fields, descriptions, extended reading"
      }
    },
    
    "scale": {
      "display-1": { "size": "128px", "lineHeight": 1.1, "weight": 700, "usage": "Hero headlines" },
      "display-2": { "size": "72px", "lineHeight": 1.15, "weight": 700, "usage": "H1 Display" },
      "heading-1": { "size": "48px", "lineHeight": 1.2, "weight": 700, "usage": "H2 Section" },
      "heading-2": { "size": "36px", "lineHeight": 1.25, "weight": 700, "usage": "H3 Subsection" },
      "heading-3": { "size": "30px", "lineHeight": 1.3, "weight": 600, "usage": "H4 Component" },
      "heading-4": { "size": "24px", "lineHeight": 1.35, "weight": 600, "usage": "H5 Card Title" },
      "heading-5": { "size": "20px", "lineHeight": 1.4, "weight": 600, "usage": "H6 Label" },
      "body": { "size": "16px", "lineHeight": 1.6, "weight": 400, "usage": "Body Primary" },
      "body-small": { "size": "14px", "lineHeight": 1.5, "weight": 400, "usage": "Body Secondary" },
      "caption": { "size": "12px", "lineHeight": 1.4, "weight": 500, "usage": "Labels, badges" }
    }
  },
  
  "spacing": {
    "base": 8,
    "unit": "px",
    "scale": {
      "0": "0",
      "1": "8px",
      "2": "16px",
      "3": "24px",
      "4": "32px",
      "5": "40px",
      "6": "48px",
      "8": "64px",
      "10": "80px",
      "12": "96px",
      "16": "128px"
    }
  },
  
  "layout": {
    "breakpoints": {
      "xs": "320px",
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },
  
  "borderRadius": {
    "none": "0",
    "brutal": "0"
  },
  
  "shadows": {
    "brutal-sm": { "offset": "2px 2px", "blur": "0", "color": "rgba(0, 0, 0, 1)" },
    "brutal": { "offset": "4px 4px", "blur": "0", "color": "rgba(0, 0, 0, 1)" },
    "brutal-lg": { "offset": "6px 6px", "blur": "0", "color": "rgba(0, 0, 0, 1)" },
    "brutal-xl": { "offset": "8px 8px", "blur": "0", "color": "rgba(0, 0, 0, 1)" },
    "brutal-brand": { "offset": "4px 4px", "blur": "0", "color": "var(--brand-primary)" }
  },
  
  "patterns": {
    "diagonalStripes": {
      "name": "DBF Diagonal Stripes",
      "angle": "-21deg",
      "spacing": "8px",
      "thickness": "0.5px",
      "opacity": {
        "light": 0.5,
        "dark": 0.15,
        "bg": {
          "light": 0.15,
          "dark": 0.08
        }
      },
      "v3Changes": {
        "spacing": "8px (was 12px)",
        "opacity": "50% (was 20%)"
      }
    },
    "grid": {
      "size": "20px",
      "opacity": { "light": 0.05, "dark": 0.03 }
    }
  },
  
  "motion": {
    "duration": {
      "instant": "0ms",
      "fast": "100ms",
      "normal": "150ms",
      "slow": "300ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "brutal": "steps(2, end)"
    }
  },
  
  "components": {
    "avatar": {
      "sizes": { "xs": "24px", "sm": "32px", "md": "40px", "lg": "48px", "xl": "64px", "2xl": "96px" }
    },
    "progress": {
      "variants": ["linear", "circular"],
      "sizes": ["sm", "md", "lg"],
      "wideMultiplier": 2
    },
    "table": {
      "variants": ["default", "striped", "bordered", "compact"]
    },
    "toast": {
      "positions": ["top-left", "top-center", "top-right", "bottom-left", "bottom-center", "bottom-right"],
      "duration": "5000ms"
    },
    "modal": {
      "sizes": { "sm": "400px", "md": "560px", "lg": "720px", "xl": "960px" }
    },
    "tabs": {
      "variants": ["line", "enclosed", "filled", "pills"]
    },
    "accordion": {
      "variants": ["default", "bordered", "filled"],
      "allowMultiple": true
    },
    "pagination": {
      "sizes": ["sm", "md", "lg"]
    },
    "stepper": {
      "variants": ["horizontal", "vertical"],
      "sizes": ["sm", "md", "lg"]
    },
    "tooltip": {
      "placements": ["top", "right", "bottom", "left"],
      "delay": { "show": "300ms", "hide": "100ms" }
    },
    "dropdown": {
      "sizes": ["sm", "md", "lg"],
      "placement": ["bottom-start", "bottom-end", "top-start", "top-end"]
    },
    "statCard": {
      "variants": ["default", "striped", "accented"]
    },
    "emptyState": {
      "variants": ["default", "compact", "illustrated"]
    }
  }
}
